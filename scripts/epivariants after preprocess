# FILTERING BASEDON HOTSPOTS
epi_1_hotspots <- epi_1_total %>% hybrid_clustering()                  
epi_R_hotspot <- epi_1_total %>% filter(epivariant_class == "R_only") %>% hybrid_clustering()
epi_MR_hotspot <- epi_1_total %>% filter(epivariant_class == "MR_only") %>% hybrid_clustering() 


epi_1_hotspots <- assign_canonical_cluster_ids(epi_1_hotspots)
epi_R_hotspot <- assign_canonical_cluster_ids(epi_R_hotspot)
epi_MR_hotspot <- assign_canonical_cluster_ids(epi_MR_hotspot)


epi_1_hotspots_enriched <- enrich_clusters(
  epi_clustered = epi_1_hotspots,
  beta_context  = beta_context,
  sample_info   = sample_info,
  cluster_col   = "canonical_cluster_id",   # swap to "dbscan_cluster_id" as needed
  sample_col    = "samples_final"
)

epi_R_hotspot_enriched <- enrich_clusters(
  epi_clustered = epi_R_hotspot,
  beta_context  = beta_context,
  sample_info   = sample_info,
  cluster_col   = "canonical_cluster_id",   # swap to "dbscan_cluster_id" as needed
  sample_col    = "samples_final"
)

epi_MR_hotspot_enriched <- enrich_clusters(
  epi_clustered = epi_MR_hotspot,
  beta_context  = beta_context,
  sample_info   = sample_info,
  cluster_col   = "canonical_cluster_id",   # swap to "dbscan_cluster_id" as needed
  sample_col    = "samples_final"
)



strong_hotspots <- epi_enriched %>%
    filter(
        in_canonical_cluster
    )

strong_hotspots1 <- epi_enriched %>%
  filter(
    in_canonical_cluster,
    direction_concordance %in% c("all_hyper", "all_hypo")
  )

strong_hotspots2 <- epi_enriched %>%
  filter(
    in_canonical_cluster,
    direction_concordance %in% c("all_hyper", "all_hypo"),
    cluster_mean_abs_delta_detail > 0.2  # effect size filter
  )

strong_hotspots3 <- epi_enriched %>%
  filter(
    in_canonical_cluster,
    direction_concordance %in% c("all_hyper", "all_hypo"),
    cluster_mean_abs_delta_detail > 0.1  # effect size filter
  )

