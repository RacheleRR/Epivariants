epi_1_total_nr <- epi_1_total %>%
  left_join(nr_beta_context, by = "region_id")

cat("Regions with NR SD available:", sum(!is.na(epi_1_total_nr$mean_nr_sd)), "\n")

cat("\nNR SD distribution across regions:\n")
print(quantile(epi_1_total_nr$mean_nr_sd,
               probs = c(0, 0.05, 0.10, 0.25, 0.5, 0.75, 0.90, 0.95, 1),
               na.rm = TRUE))

# Use the 90th percentile as the "high variability" threshold
nr_sd_high_thresh <- quantile(epi_1_total_nr$mean_nr_sd, 0.90, na.rm = TRUE)
cat("\nUsing NR SD 90th percentile as high-variability threshold:", 
    round(nr_sd_high_thresh, 4), "\n")

nr_sd_p10 <-   quantile(epi_1_total_nr$mean_nr_sd, 0.10, na.rm = TRUE)
cat("\nUsing NR SD 5th percentile as low-variability threshold:", 
    round(nr_sd_low_thresh, 4), "\n") 

nr_sd_low_thresh <- quantile(epi_1_total_nr$mean_nr_sd, 0.05, na.rm = TRUE)
cat("\nUsing NR SD 5th percentile as low-variability threshold:", 
    round(nr_sd_low_thresh, 4), "\n")
# ============================================================
# OPTIONS 14, 15, 16: NR_sd < 0.03 (near-invariant in NR)
#   14: pre-filter + cluster
#   15: pre-filter + cluster + enrich (delta+pct)
#   16: pre-filter + cluster + enrich (nSD)
# ============================================================

pre_nr_low <- epi_1_total_nr %>%
  filter(mean_nr_sd < 0.03)
