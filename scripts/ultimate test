#PLOTS 

library(ggplot2)
library(patchwork)
library(tidyverse)

# ============================================================
# PLOT 1: NR SD DISTRIBUTION
# Helps decide where to set the threshold visually
# ============================================================

p1 <- ggplot(epi_1_total_nr, aes(x = mean_nr_sd)) +
  geom_histogram(bins = 50, fill = "#4A90D9", color = "white", linewidth = 0.2) +
  geom_vline(xintercept = 0.03, color = "red",    linetype = "dashed", linewidth = 0.8) +
  geom_vline(xintercept = nr_sd_low_thresh, color = "orange", linetype = "dashed", linewidth = 0.8) +
  geom_vline(xintercept = nr_sd_p10, color = "purple", linetype = "dashed", linewidth = 0.8) +
  geom_vline(xintercept = nr_sd_high_thresh, color = "darkgreen", linetype = "dashed", linewidth = 0.8) +
  annotate("text", x = 0.03,           y = Inf, label = "fixed 0.03",  
           color = "red",       vjust = 2, hjust = -0.1, size = 3) +
  annotate("text", x = nr_sd_low_thresh,      y = Inf, label = "5th pct",     
           color = "orange",    vjust = 3.5, hjust = -0.1, size = 3) +
  annotate("text", x = nr_sd_p10,      y = Inf, label = "10th pct",    
           color = "purple",    vjust = 5, hjust = -0.1, size = 3) +
  annotate("text", x = nr_sd_high_thresh, y = Inf, label = "90th pct", 
           color = "darkgreen", vjust = 2, hjust = -0.1, size = 3) +
  labs(title = "NR-only SD distribution across regions",
       subtitle = "Dashed lines = candidate thresholds",
       x = "Mean NR SD per region", y = "Count") +
  theme_minimal(base_size = 11)

ggsave("diagnostic_01_NR_sd_distribution.png", p1, width = 10, height = 5, dpi = 300)


# ============================================================
# PLOT 2: NR SD vs mean_abs_delta_detail (scatter)
# Shows whether low-SD regions also have high effect sizes
# Ideal: low NR SD + high delta = real biological signal
# ============================================================

p2 <- ggplot(epi_1_total_nr, 
             aes(x = mean_nr_sd, 
                 y = mean_abs_delta_detail,
                 color = epivariant_class)) +
  geom_point(alpha = 0.5, size = 1.5) +
  geom_vline(xintercept = 0.03,         color = "red",       linetype = "dashed") +
  geom_vline(xintercept = nr_sd_low_thresh,    color = "orange",    linetype = "dashed") +
  geom_vline(xintercept = nr_sd_p10,    color = "purple",    linetype = "dashed") +
  geom_hline(yintercept = 0.15,         color = "black",     linetype = "dotted") +
  scale_color_manual(values = c(
    R_only          = "#B71C1C",
    MR_only         = "#1B5E20",
    Shared_R_and_MR = "#0D47A1"
  )) +
  labs(title = "NR SD vs Effect Size (mean |delta beta|)",
       subtitle = "Bottom-right = low NR variability + high effect = most interesting",
       x = "Mean NR SD (lower = more invariant in NR)",
       y = "Mean |delta beta| (higher = bigger effect)",
       color = "Epivariant class") +
  theme_minimal(base_size = 11)

ggsave("diagnostic_02_NR_sd_vs_delta.png", p2, width = 10, height = 6, dpi = 300)


# ============================================================
# PLOT 3: NR SD vs abs(median_nSD_detail) (scatter)  
# Shows where nSD gets inflated by low background SD
# Points top-left = high nSD but low NR SD = likely inflated
# ============================================================

p3 <- ggplot(epi_1_total_nr,
             aes(x = mean_nr_sd,
                 y = abs(median_nSD_detail),
                 color = epivariant_class)) +
  geom_point(alpha = 0.5, size = 1.5) +
  geom_vline(xintercept = 0.03,      color = "red",    linetype = "dashed") +
  geom_vline(xintercept = nr_sd_low_thresh, color = "orange", linetype = "dashed") +
  geom_hline(yintercept = 5,         color = "grey40", linetype = "dotted") +
  geom_hline(yintercept = 10,        color = "black",  linetype = "dotted") +
  scale_color_manual(values = c(
    R_only          = "#B71C1C",
    MR_only         = "#1B5E20",
    Shared_R_and_MR = "#0D47A1"
  )) +
  labs(title = "NR SD vs |median nSD| — detecting inflated nSD",
       subtitle = "Top-left = suspiciously high nSD with low NR variability",
       x = "Mean NR SD",
       y = "|median nSD from background|",
       color = "Epivariant class") +
  theme_minimal(base_size = 11)

ggsave("diagnostic_03_NR_sd_vs_nsd.png", p3, width = 10, height = 6, dpi = 300)


# ============================================================
# PLOT 4: REGIONS SURVIVING EACH FILTER (bar chart)
# Direct visual comparison of how strict each option is
# ============================================================

# Build survival counts for all pre-cluster filters
filter_survival <- tibble(
  filter_name = c(
    "Unfiltered",
    "abs(nSD) >= 5",
    "abs(nSD) >= 10",
    "bg_sd < 0.03",
    "bg_sd > 0.10",
    "NR_sd < 0.03 (fixed)",
    paste0("NR_sd <= 5th pct\n(", round(nr_sd_low_thresh, 3), ")"),
    paste0("NR_sd <= 10th pct\n(", round(nr_sd_p10, 3), ")"),
    paste0("NR_sd < 90th pct\n(", round(nr_sd_high_thresh, 3), ")")
  ),
  n_regions = c(
    nrow(epi_1_total),
    nrow(epi_1_total %>% filter(abs(median_nSD_detail) >= 5)),
    nrow(epi_1_total %>% filter(abs(median_nSD_detail) >= 10)),
    nrow(epi_1_total %>% filter(mean_nSD_detail_bg < 0.03)),
    nrow(epi_1_total %>% filter(mean_nSD_detail_bg > 0.10)),
    nrow(epi_1_total_nr %>% filter(mean_nr_sd < 0.03)),
    nrow(pre_nr_stable_low),
    nrow(epi_1_total_nr %>% filter(mean_nr_sd < nr_sd_p10 )),
    nrow(pre_nr_stable)
  ),
  filter_type = c(
    "none",
    "nSD", "nSD",
    "bg_sd", "bg_sd",
    "NR_sd", "NR_sd", "NR_sd", "NR_sd"
  )
) %>%
  mutate(
    pct_retained = round(n_regions / nrow(epi_1_total) * 100, 1),
    filter_name  = factor(filter_name, levels = filter_name)  # keep order
  )

p4 <- ggplot(filter_survival, 
             aes(x = filter_name, y = n_regions, fill = filter_type)) +
  geom_col(color = "white", linewidth = 0.3) +
  geom_text(aes(label = paste0(n_regions, "\n(", pct_retained, "%)")),
            vjust = -0.3, size = 3) +
  scale_fill_manual(values = c(
    none   = "#9E9E9E",
    nSD    = "#FF8F00",
    bg_sd  = "#1565C0",
    NR_sd  = "#2E7D32"
  )) +
  labs(title = "Regions surviving each pre-cluster filter",
       subtitle = "Shows how strict each filter is relative to unfiltered",
       x = NULL, y = "N regions", fill = "Filter type") +
  theme_minimal(base_size = 11) +
  theme(axis.text.x = element_text(angle = 30, hjust = 1, size = 9))

ggsave("diagnostic_04_filter_survival.png", p4, width = 12, height = 6, dpi = 300)


# ============================================================
# PLOT 5: REGIONS SURVIVING EACH FULL OPTION (from summary table)
# Shows the complete picture including post-cluster filtering
# ============================================================

p5 <- summary_table %>%
  mutate(
    option = factor(option, levels = option),  # keep order
    group  = case_when(
      grepl("^1_|^2_|^3_", option)  ~ "A: no pre-filter",
      grepl("^4_|^5_|^6_", option)  ~ "B: abs(nSD) pre-filter",
      grepl("^7_|^8_|^9_|^10", option) ~ "C: bg_sd < 0.03",
      grepl("^11_|^12_|^13_", option)  ~ "D: bg_sd > 0.1",
      grepl("^14_|^15_|^16_", option)  ~ "E: NR_sd < 0.03",
      grepl("^17_|^18_|^19_", option)  ~ "F: NR_sd stable",
      TRUE ~ "other"
    )
  ) %>%
  ggplot(aes(x = option, y = n_regions, fill = group)) +
  geom_col(color = "white", linewidth = 0.2) +
  geom_text(aes(label = n_regions), vjust = -0.3, size = 2.5) +
  scale_fill_brewer(palette = "Set2") +
  labs(title = "Regions in canonical clusters per option",
       subtitle = "Full pipeline including post-cluster filtering",
       x = NULL, y = "N regions", fill = "Filter group") +
  theme_minimal(base_size = 10) +
  theme(axis.text.x = element_text(angle = 45, hjust = 1, size = 7))

ggsave("diagnostic_05_option_comparison.png", p5, width = 16, height = 6, dpi = 300)


# ============================================================
# PLOT 6: EFFECT SIZE DISTRIBUTION BY FILTER GROUP
# Boxplots of mean_abs_delta_detail for regions surviving
# each pre-cluster filter — checks if filters enrich for
# high-effect regions or just arbitrarily remove things
# ============================================================

effect_by_filter <- bind_rows(
  epi_1_total %>% 
    mutate(filter_name = "Unfiltered"),
  epi_1_total %>% 
    filter(abs(median_nSD_detail) >= 5) %>% 
    mutate(filter_name = "abs(nSD) >= 5"),
  epi_1_total %>% 
    filter(abs(median_nSD_detail) >= 10) %>% 
    mutate(filter_name = "abs(nSD) >= 10"),
  epi_1_total %>% 
    filter(mean_nSD_detail_bg < 0.03) %>% 
    mutate(filter_name = "bg_sd < 0.03"),
  epi_1_total_nr %>% 
    filter(mean_nr_sd < 0.03) %>% 
    mutate(filter_name = "NR_sd < 0.03"),
  pre_nr_stable_low %>% 
    mutate(filter_name = paste0("NR_sd <= 5th pct\n(", round(nr_sd_low_thresh,3), ")")),
  epi_1_total_nr %>% 
  filter(mean_nr_sd <nr_sd_p10 )%>%
    mutate(filter_name = paste0("NR_sd <= 10th pct\n(", round(nr_sd_p10,3), ")"))
) %>%
  mutate(filter_name = factor(filter_name, 
                               levels = c("Unfiltered", "abs(nSD) >= 5",
                                          "abs(nSD) >= 10", "bg_sd < 0.03",
                                          "NR_sd < 0.03",
                                          paste0("NR_sd <= 5th pct\n(", round(nr_sd_low_thresh,3), ")"),
                                          paste0("NR_sd <= 10th pct\n(", round(nr_sd_p10,3), ")"))))

p6 <- ggplot(effect_by_filter,
             aes(x = filter_name, y = mean_abs_delta_detail, fill = filter_name)) +
  geom_boxplot(outlier.size = 0.8, outlier.alpha = 0.4) +
  geom_hline(yintercept = 0.15, linetype = "dashed", color = "black") +
  scale_fill_brewer(palette = "Set3") +
  labs(title = "Effect size distribution per filter group",
       subtitle = "Dashed line = 0.15 delta beta threshold | Good filter = shifts distribution up",
       x = NULL, 
       y = "Mean |delta beta| per region") +
  theme_minimal(base_size = 11) +
  theme(legend.position = "none",
        axis.text.x = element_text(angle = 30, hjust = 1))

ggsave("diagnostic_06_effect_size_by_filter.png", p6, width = 12, height = 6, dpi = 300)

# Print all together
(p1 / p4) | (p2 / p3)

