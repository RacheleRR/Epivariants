make_plot(opt16, "opt16_NR_sd_lt_003_cluster_filtered_nsd")


# ============================================================
# OPTIONS 17, 18, 19: Remove high NR SD (naturally variable in NR)
# Logic: these regions are variable even in NR so an "outlier"
# there is less meaningful — removing them keeps only stable loci
#   17: NR_sd < 90th pct + cluster
#   18: NR_sd < 90th pct + cluster + enrich (delta+pct)
#   19: NR_sd < 90th pct + cluster + enrich (nSD)
# ============================================================

pre_nr_stable <- epi_1_total_nr %>%
  filter(mean_nr_sd < nr_sd_high_thresh)
cat("\n\nRegions after removing high NR SD (< 90th pct =",
    round(nr_sd_high_thresh, 4), "):", nrow(pre_nr_stable), "\n")

cat("\n\n========== OPTION 17: NR_sd < 90th pct + cluster ==========\n")
opt17 <- cluster_pipeline(pre_nr_stable)
cat("Regions in canonical clusters:", nrow(opt17), "\n")
make_plot(opt17, "opt17_NR_sd_stable_cluster")

cat("\n\n========== OPTION 18: NR_sd < 90th pct + cluster + filtering delta+pct ==========\n")
opt18 <- cluster_pipeline_enriched(pre_nr_stable)
cat("Regions after delta+pct cluster filtering:", nrow(opt18), "\n")
make_plot(opt18, "opt18_NR_sd_stable_cluster_filtered_delta_pct")

cat("\n\n========== OPTION 19: NR_sd < 90th pct + cluster + filtering nSD ==========\n")
opt19 <- cluster_pipeline_enriched_nsd(pre_nr_stable)
cat("Regions after nSD cluster filtering:", nrow(opt19), "\n")
make_plot(opt19, "opt19_NR_sd_stable_cluster_filtered_nsd")


# ============================================================
# OPTIONS 20, 21, 22: keep low NR SD (naturally unvariable in NR)
# Logic: these regions are variable even in NR so an "outlier"
# there is less meaningful — removing them keeps only stable loci
#   20: NR_sd < 5th pct + cluster
#   21: NR_sd < 5th pct + cluster + enrich (delta+pct)
#   22: NR_sd < 5th pct + cluster + enrich (nSD)
# ============================================================

pre_nr_stable_low <- epi_1_total_nr %>%
  filter(mean_nr_sd < nr_sd_low_thresh)
cat("\n\nRegions after removing high NR SD (< 5th pct =",
    round(nr_sd_low_thresh, 4), "):", nrow(pre_nr_stable_low), "\n")

cat("\n\n========== OPTION 20: NR_sd < 5th pct + cluster ==========\n")
opt20 <- cluster_pipeline(pre_nr_stable_low)
cat("Regions in canonical clusters:", nrow(opt20), "\n")
make_plot(opt20, "opt20_NR_sd_stable_cluster")

cat("\n\n========== OPTION 21: NR_sd < 5th pct + cluster + filtering delta+pct ==========\n")
opt21 <- cluster_pipeline_enriched(pre_nr_stable_low)
cat("Regions after delta+pct cluster filtering:", nrow(opt21), "\n")
make_plot(opt21, "opt21_NR_sd_stable_cluster_filtered_delta_pct")

cat("\n\n========== OPTION 22: NR_sd < 5th pct + cluster + filtering nSD ==========\n")
opt22 <- cluster_pipeline_enriched_nsd(pre_nr_stable_low)
cat("Regions after nSD cluster filtering:", nrow(opt22), "\n")
make_plot(opt22, "opt22_NR_sd_stable_cluster_filtered_nsd")



