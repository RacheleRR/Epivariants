summary_table <- bind_rows(
  
  # Group A: no pre-filter
  tibble(option = "1_unfiltered_cluster",
         n_regions = nrow(opt1),
         filter_logic = "none → cluster"),
  tibble(option = "2_unfiltered_cluster_filtered_delta_pct",
         n_regions = nrow(opt2),
         filter_logic = "none → cluster → enrich (delta+pct)"),
  tibble(option = "3_unfiltered_cluster_filtered_nsd",
         n_regions = nrow(opt3),
         filter_logic = "none → cluster → enrich (nSD)"),
  
  # Group B: pre-filter by abs(median_nSD)
  imap_dfr(opt4_results, ~ tibble(
    option       = paste0("4_", .y, "_cluster"),
    n_regions    = nrow(.x),
    filter_logic = paste0("abs(median_nSD) >= ", gsub("nsd_ge_","", .y), " → cluster")
  )),
  imap_dfr(opt5_results, ~ tibble(
    option       = paste0("5_", .y, "_cluster_filtered_delta_pct"),
    n_regions    = nrow(.x),
    filter_logic = paste0("abs(median_nSD) >= ", gsub("nsd_ge_","", .y), " → cluster → enrich (delta+pct)")
  )),
  imap_dfr(opt6_results, ~ tibble(
    option       = paste0("6_", .y, "_cluster_filtered_nsd"),
    n_regions    = nrow(.x),
    filter_logic = paste0("abs(median_nSD) >= ", gsub("nsd_ge_","", .y), " → cluster → enrich (nSD)")
  )),
  
  # Group C: bg_sd < 0.03
  tibble(option = "7_bg_lt_003_cluster",
         n_regions = nrow(opt7),
         filter_logic = "bg_sd < 0.03 → cluster"),
  tibble(option = "8_bg_lt_003_cluster_filtered_delta_pct",
