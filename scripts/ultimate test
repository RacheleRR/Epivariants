opt14 <- cluster_pipeline(pre_nr_low)
cat("Regions in canonical clusters:", nrow(opt14), "\n")
make_plot(opt14, "opt14_NR_sd_lt_003_cluster")

cat("\n\n========== OPTION 15: NR_sd < 0.03 + cluster + filtering delta+pct ==========\n")
opt15 <- cluster_pipeline_enriched(pre_nr_low)
cat("Regions after delta+pct cluster filtering:", nrow(opt15), "\n")
make_plot(opt15, "opt15_NR_sd_lt_003_cluster_filtered_delta_pct")

