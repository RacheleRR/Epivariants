# ============================================================
# HELPERS
# ============================================================

cluster_pipeline <- function(epi_df) {
  if (nrow(epi_df) < 3) {
    cat("  Too few regions to cluster\n")
    return(epi_df %>% mutate(in_canonical_cluster = FALSE))
  }
  epi_df %>%
    hybrid_clustering() %>%
    assign_canonical_cluster_ids() %>%
    filter(in_canonical_cluster == TRUE)
}

# Post-cluster filter: delta + pct
cluster_pipeline_enriched <- function(epi_df) {
  if (nrow(epi_df) < 3) {
    cat("  Too few regions to cluster\n")
    return(epi_df %>% mutate(in_canonical_cluster = FALSE))
  }
  epi_df %>%
    hybrid_clustering() %>%
    assign_canonical_cluster_ids() %>%
    filter(in_canonical_cluster == TRUE) %>%
    enrich_clusters(
      beta_context = beta_context,
      sample_info  = sample_info,
      cluster_col  = "canonical_cluster_id",
      sample_col   = "samples_final"
    ) %>%
    filter(
      cluster_mean_abs_delta_detail >= 0.15,
      cluster_pct_cpgs_02_detail    >= 50
    )
}

# Post-cluster filter: nSD only
cluster_pipeline_enriched_nsd <- function(epi_df) {
  if (nrow(epi_df) < 3) {
    cat("  Too few regions to cluster\n")
    return(epi_df %>% mutate(in_canonical_cluster = FALSE))
  }
  epi_df %>%
    hybrid_clustering() %>%
    assign_canonical_cluster_ids() %>%
    filter(in_canonical_cluster == TRUE) %>%
    enrich_clusters(
      beta_context = beta_context,
      sample_info  = sample_info,
      cluster_col  = "canonical_cluster_id",
      sample_col   = "samples_final"
    ) %>%
    filter(abs(cluster_median_nSD_detail) >= 10)   # fixed syntax
}

make_plot <- function(epi_df, label, n_clusters = 4, min_epi_pts = 3) {
  if (nrow(epi_df) == 0) {
    cat("  Skipping plot for", label, "— 0 regions\n")
    return(invisible(NULL))
  }
  cat("\n=== Plotting:", label, "| regions:", nrow(epi_df), "===\n")
  plot_cluster_landscape(
    epi_clustered    = epi_df,
    master_annotated = master_annotated,
    beta_long_base   = beta_long_base,
    lookup_mega      = lookup_mega,
    cpg_positions    = cpg_positions,
    n_clusters       = n_clusters,
    window_cpgs      = 200,
    cluster_type     = "any",
    min_epi_pts      = min_epi_pts,
    title            = paste0(label, "_")
  )
}

nsd_thresholds <- c(5, 10)


# ============================================================
# OPTION 1: Unfiltered + cluster
# ============================================================

cat("\n\n========== OPTION 1: Unfiltered + cluster ==========\n")
opt1 <- cluster_pipeline(epi_1_total)
cat("Regions in canonical clusters:", nrow(opt1), "\n")
make_plot(opt1, "opt1_unfiltered_cluster")


# ============================================================
# OPTION 2: Unfiltered + cluster + cluster filtering (delta+pct)
# ============================================================

cat("\n\n========== OPTION 2: Unfiltered + cluster + cluster filtering delta+pct ==========\n")
opt2 <- cluster_pipeline_enriched(epi_1_total)
cat("Regions after cluster filtering:", nrow(opt2), "\n")
make_plot(opt2, "opt2_unfiltered_cluster_filtered_delta_pct")


# ============================================================
# OPTION 3: Unfiltered + cluster + cluster filtering (nSD)
# ============================================================

cat("\n\n========== OPTION 3: Unfiltered + cluster + cluster filtering nSD ==========\n")
opt3 <- cluster_pipeline_enriched_nsd(epi_1_total)
cat("Regions after nSD cluster filtering:", nrow(opt3), "\n")
make_plot(opt3, "opt3_unfiltered_cluster_filtered_nsd")


# ============================================================
# OPTIONS 4, 5, 6: abs(median_nSD_detail) >= 5 or 10
#   4: pre-filter + cluster
#   5: pre-filter + cluster + enrich (delta+pct)
#   6: pre-filter + cluster + enrich (nSD)
# ============================================================

opt4_results <- list()
opt5_results <- list()
opt6_results <- list()

for (thresh in nsd_thresholds) {
  
  label <- paste0("nsd_ge_", thresh)
  
  pre <- epi_1_total %>%
    filter(abs(median_nSD_detail) >= thresh)
  cat("\n\nnSD pre-filter (>=", thresh, ") regions:", nrow(pre), "\n")
  
  cat("\n========== OPTION 4:", label, "+ cluster ==========\n")
  opt4 <- cluster_pipeline(pre)
  cat("Regions in canonical clusters:", nrow(opt4), "\n")
  opt4_results[[label]] <- opt4
  make_plot(opt4, paste0("opt4_", label, "_cluster"))
  
  cat("\n========== OPTION 5:", label, "+ cluster + filtering delta+pct ==========\n")
  opt5 <- cluster_pipeline_enriched(pre)
  cat("Regions after delta+pct cluster filtering:", nrow(opt5), "\n")
  opt5_results[[label]] <- opt5
  make_plot(opt5, paste0("opt5_", label, "_cluster_filtered_delta_pct"))
  
  cat("\n========== OPTION 6:", label, "+ cluster + filtering nSD ==========\n")
  opt6 <- cluster_pipeline_enriched_nsd(pre)
  cat("Regions after nSD cluster filtering:", nrow(opt6), "\n")
  opt6_results[[label]] <- opt6
  make_plot(opt6, paste0("opt6_", label, "_cluster_filtered_nsd"))
}


# ============================================================
# OPTIONS 7, 8, 9: bg_sd < 0.03
#   7: pre-filter + cluster
#   8: pre-filter + cluster + enrich (delta+pct)
#   9: pre-filter + cluster + enrich (nSD)
# ============================================================

pre_bg_low <- epi_1_total %>%
  filter(mean_nSD_detail_bg < 0.03)
cat("\n\nRegions after bg_sd < 0.03 filter:", nrow(pre_bg_low), "\n")

cat("\n\n========== OPTION 7: bg_sd < 0.03 + cluster ==========\n")
opt7 <- cluster_pipeline(pre_bg_low)
cat("Regions in canonical clusters:", nrow(opt7), "\n")
make_plot(opt7, "opt7_bg_lt_003_cluster")

cat("\n\n========== OPTION 8: bg_sd < 0.03 + cluster + filtering delta+pct ==========\n")
opt8 <- cluster_pipeline_enriched(pre_bg_low)
cat("Regions after delta+pct cluster filtering:", nrow(opt8), "\n")
make_plot(opt8, "opt8_bg_lt_003_cluster_filtered_delta_pct")

cat("\n\n========== OPTION 9: bg_sd < 0.03 + cluster + filtering nSD ==========\n")
opt9 <- cluster_pipeline_enriched_nsd(pre_bg_low)
cat("Regions after nSD cluster filtering:", nrow(opt9), "\n")
make_plot(opt9, "opt9_bg_lt_003_cluster_filtered_nsd")


# ============================================================
# OPTIONS 10a-g: bg_sd < 0.03 + combined pre-cluster effect filters
# All followed by cluster_pipeline (no post-cluster filtering —
# the effect filter is applied BEFORE clustering here)
# ============================================================

cat("\n\n========== OPTIONS 10a-g: bg_sd < 0.03 + combined effect filters ==========\n")

effect_filters <- list(
  "10a_delta"           = quote(mean_abs_delta_detail >= 0.15),
  "10b_pct"             = quote(pct_cpgs_02_detail >= 50),
  "10c_nsd"             = quote(abs(median_nSD_detail) >= 10),
  "10d_delta_pct"       = quote(mean_abs_delta_detail >= 0.15 & pct_cpgs_02_detail >= 50),
  "10e_delta_nsd"       = quote(mean_abs_delta_detail >= 0.15 & abs(median_nSD_detail) >= 10),
  "10f_pct_nsd"         = quote(pct_cpgs_02_detail >= 50 & abs(median_nSD_detail) >= 10),
  "10g_delta_pct_nsd"   = quote(mean_abs_delta_detail >= 0.15 & pct_cpgs_02_detail >= 50 & abs(median_nSD_detail) >= 10)
)

opt10_results <- list()

for (ef_name in names(effect_filters)) {
  
  cat("\n========== OPTION", ef_name, "==========\n")
  
  filtered <- pre_bg_low %>%
    filter(!!effect_filters[[ef_name]])
  
  cat("Regions after effect filter:", nrow(filtered), "\n")
  
  if (nrow(filtered) < 3) {
    cat("  Skipping — too few regions\n")
    next
  }
  
  clustered <- cluster_pipeline(filtered)
  cat("Regions in canonical clusters:", nrow(clustered), "\n")
  
  opt10_results[[ef_name]] <- clustered
  make_plot(clustered, paste0("opt", ef_name, "_bg_lt_003_cluster"))
}


# ============================================================
# OPTIONS 11, 12, 13: bg_sd > 0.1
#   11: pre-filter + cluster
#   12: pre-filter + cluster + enrich (delta+pct)
#   13: pre-filter + cluster + enrich (nSD)
# ============================================================

pre_bg_high <- epi_1_total %>%
  filter(mean_nSD_detail_bg > 0.1)
cat("\n\nRegions after bg_sd > 0.1 filter:", nrow(pre_bg_high), "\n")

cat("\n\n========== OPTION 11: bg_sd > 0.1 + cluster ==========\n")
opt11 <- cluster_pipeline(pre_bg_high)
cat("Regions in canonical clusters:", nrow(opt11), "\n")
make_plot(opt11, "opt11_bg_gt_01_cluster")

cat("\n\n========== OPTION 12: bg_sd > 0.1 + cluster + filtering delta+pct ==========\n")
opt12 <- cluster_pipeline_enriched(pre_bg_high)
cat("Regions after delta+pct cluster filtering:", nrow(opt12), "\n")
make_plot(opt12, "opt12_bg_gt_01_cluster_filtered_delta_pct")

cat("\n\n========== OPTION 13: bg_sd > 0.1 + cluster + filtering nSD ==========\n")
opt13 <- cluster_pipeline_enriched_nsd(pre_bg_high)
cat("Regions after nSD cluster filtering:", nrow(opt13), "\n")
make_plot(opt13, "opt13_bg_gt_01_cluster_filtered_nsd")


