         filter_logic = "bg_sd < 0.03 → cluster → enrich (nSD)"),
  imap_dfr(opt10_results, ~ tibble(
    option       = paste0("10_bg_lt_003_", .y, "_cluster"),
    n_regions    = nrow(.x),
    filter_logic = paste0("bg_sd < 0.03 + effect filter [", .y, "] → cluster")
  )),
  
  # Group D: bg_sd > 0.1
  tibble(option = "11_bg_gt_01_cluster",
         n_regions = nrow(opt11),
         filter_logic = "bg_sd > 0.1 → cluster"),
  tibble(option = "12_bg_gt_01_cluster_filtered_delta_pct",
         n_regions = nrow(opt12),
         filter_logic = "bg_sd > 0.1 → cluster → enrich (delta+pct)"),
  tibble(option = "13_bg_gt_01_cluster_filtered_nsd",
         n_regions = nrow(opt13),
         filter_logic = "bg_sd > 0.1 → cluster → enrich (nSD)"),
  
  # Group E: NR_sd < 0.03
  tibble(option = "14_NR_sd_lt_003_cluster",
         n_regions = nrow(opt14),
         filter_logic = "NR_sd < 0.03 → cluster"),
  tibble(option = "15_NR_sd_lt_003_cluster_filtered_delta_pct",
         n_regions = nrow(opt15),
         filter_logic = "NR_sd < 0.03 → cluster → enrich (delta+pct)"),
  tibble(option = "16_NR_sd_lt_003_cluster_filtered_nsd",
         n_regions = nrow(opt16),
         filter_logic = "NR_sd < 0.03 → cluster → enrich (nSD)"),
  
  # Group F: remove high NR SD (< 90th percentile)
  tibble(option = "17_NR_sd_stable_cluster",
         n_regions = nrow(opt17),
         filter_logic = paste0("NR_sd < 90th pct (", round(nr_sd_high_thresh,4), ") → cluster")),
