print(summary_table)
write_tsv(summary_table, "epivariant_categories_summary.tsv")

cat("\n✓ All 13 categories created with adaptive hotspot thresholds!\n")
cat("✓ Hotspot parameters automatically adjusted based on:\n")
cat("  - Dataset size (larger sets → higher threshold)\n")
cat("  - Biological context (promoters → smaller window)\n")
cat("  - Window size (smaller windows → lower threshold)\n\n")


# ============================================================
# VALIDATION CHECKS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("VALIDATION: Checking hotspot quality\n")
cat(paste(rep("=", 70), collapse = ""), "\n\n")

validate_hotspots <- function(epi_df, name) {
  
  if (!"in_hotspot" %in% colnames(epi_df)) {
    cat(name, ": No hotspot info\n")
    return()
  }
  
  n_total <- nrow(epi_df)
  n_in_hs <- sum(epi_df$in_hotspot, na.rm = TRUE)
  pct_in_hs <- round(n_in_hs / n_total * 100, 1)
  n_hs <- n_distinct(na.omit(epi_df$hotspot_id))
  
  cat(name, ":\n")
  cat("  Total regions:    ", n_total, "\n")
  cat("  In hotspots:      ", n_in_hs, " (", pct_in_hs, "%)\n", sep="")
  cat("  Unique hotspots:  ", n_hs, "\n")
  
  # Flags
  if (pct_in_hs > 60) {
    cat("  ⚠️ Warning: >60% in hotspots (threshold may be too low)\n")
  } else if (pct_in_hs < 3 && n_total > 100) {
    cat("  ⚠️ Warning: <3% in hotspots (threshold may be too high)\n")
  } else {
    cat("  ✓ Reasonable proportion\n")
  }
  
  if (n_hs > 200) {
    cat("  ⚠️ Warning: >200 hotspots (may be too many)\n")
  } else if (n_hs < 3 && n_in_hs > 0) {
    cat("  ⚠️ Warning: <3 hotspots (may be too few)\n")
  } else if (n_hs > 0) {
    cat("  ✓ Reasonable number of hotspots\n")
  }
  
  cat("\n")
}

# Run validation on key categories
validate_hotspots(epi_1_clean, "epi_1_clean")
validate_hotspots(epi_4_filt_annot, "epi_4_filt_annot")
validate_hotspots(epi_7_filt_annot_beta, "epi_7_filt_annot_beta")
validate_hotspots(epi_10_R_hotspot, "epi_10_R_hotspot")
validate_hotspots(epi_11_MR_hotspot, "epi_11_MR_hotspot")


# ============================================================
# KEY DIFFERENCES FROM YOUR ORIGINAL CODE
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("KEY IMPROVEMENTS OVER DEFAULT PARAMETERS\n")
cat(paste(rep("=", 70), collapse = ""), "\n\n")

cat("1. ADAPTIVE THRESHOLDS:\n")
cat("   - epi_1_clean (50k regions):   min_count ≈ 20-25\n")
cat("   - epi_4_filt_annot (5k):       min_count ≈ 5-7\n")
cat("   - epi_7_filt_annot_beta (1.5k): min_count ≈ 2-3\n")
cat("   Instead of: min_count = 3 for all\n\n")

cat("2. CONTEXT-AWARE WINDOWS:\n")
cat("   - Promoter analyses: 0.5 Mb window + stricter overlap\n")
cat("   - Genome-wide:       1 Mb window + any overlap\n")
cat("   Instead of: 1 Mb window for everything\n\n")

cat("3. PROPER SUBSET HANDLING:\n")
cat("   - R-specific and MR-specific hotspots: re-computed on subsets\n")
cat("   - Not just filtering the global hotspot annotations\n\n")

cat("Result: Biologically meaningful hotspots at every filtering level!\n")
```

---

## Quick Reference: When to Use Each Category

```r
# For BASELINE statistics:
epi_1_clean              # All reproducible epivariants

# For METHOD VALIDATION:
epi_2_clean_strict       # Only high-confidence (4-5 methods)

# For HOTSPOT ANALYSIS (genome-wide):
epi_3_filt_hs            # All epivariants in hotspots
epi_8_filt_beta_hs       # Strong effects in hotspots

# For GENE ANALYSIS:
epi_4_filt_annot         # All promoter/UTR regions
epi_5_filt_annot_hs      # Promoter/UTR in hotspots

# For EFFECT SIZE ANALYSIS:
epi_6_filt_beta          # Strong effects genome-wide

# For TOP CANDIDATES (validation):
epi_9_filt_annot_beta_hs # GOLD STANDARD

# For GROUP COMPARISONS:
epi_10_R_hotspot         # R-specific hotspot clustering
epi_11_MR_hotspot        # MR-specific hotspot clustering

# For CpG CONTEXT:
epi_12_shores            # CpG island shores/shelves

# For REGULATORY OVERLAP:
epi_13_cCRE              # ENCODE cis-regulatory elements
```

