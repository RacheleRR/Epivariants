cat(paste(rep("=", 70), collapse = ""), "\n")

epi_13_cCRE <- get_epivariants(
  annotation_filter = list(in_cre = "Yes")
)

cat("ENCODE cCRE regions: ", nrow(epi_13_cCRE), "\n")
write_tsv(epi_13_cCRE, "epi_13_cCRE.tsv")


# ============================================================
# SUMMARY TABLE
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("SUMMARY OF ALL 13 CATEGORIES\n")
cat(paste(rep("=", 70), collapse = ""), "\n\n")

summary_table <- tibble(
  Category = 1:13,
  Name = c(
    "epi_1_clean", "epi_2_clean_strict", "epi_3_filt_hs",
    "epi_4_filt_annot", "epi_5_filt_annot_hs", "epi_6_filt_beta",
    "epi_7_filt_annot_beta", "epi_8_filt_beta_hs", "epi_9_filt_annot_beta_hs",
    "epi_10_R_hotspot", "epi_11_MR_hotspot", "epi_12_shores", "epi_13_cCRE"
  ),
  N_regions = c(
    nrow(epi_1_clean), nrow(epi_2_clean_strict), nrow(epi_3_filt_hs),
    nrow(epi_4_filt_annot), nrow(epi_5_filt_annot_hs), nrow(epi_6_filt_beta),
    nrow(epi_7_filt_annot_beta), nrow(epi_8_filt_beta_hs), 
    nrow(epi_9_filt_annot_beta_hs),
    nrow(epi_10_R_hotspot), nrow(epi_11_MR_hotspot),
    nrow(epi_12_shores), nrow(epi_13_cCRE)
  ),
  Description = c(
    "All reproducible (baseline)",
    "High-quality only (4-5 methods)",
    "All → filtered to hotspots",
    "Promoter/UTR regions",
    "Promoter/UTR → filtered to hotspots",
    "Strong effect size (Δβ ≥ 0.2)",
    "Promoter/UTR + strong effect",
    "Strong effect → filtered to hotspots",
    "Promoter/UTR + strong + hotspots (GOLD)",
    "R-only regions in hotspots",
    "MR-only regions in hotspots",
    "CpG island shores/shelves/islands",
    "ENCODE cis-regulatory elements"
