## Save Everything

```r
# Create a master list
all_categories <- list(
  epi_1_clean = epi_1_clean,
  epi_2_clean_strict = epi_2_clean_strict,
  epi_3_filt_hs = epi_3_filt_hs,
  epi_4_filt_annot = epi_4_filt_annot,
  epi_5_filt_annot_hs = epi_5_filt_annot_hs,
  epi_6_filt_beta = epi_6_filt_beta,
  epi_7_filt_annot_beta = epi_7_filt_annot_beta,
  epi_8_filt_beta_hs = epi_8_filt_beta_hs,
  epi_9_filt_annot_beta_hs = epi_9_filt_annot_beta_hs,
  epi_10_R_hotspot = epi_10_R_hotspot,
  epi_11_MR_hotspot = epi_11_MR_hotspot,
  epi_12_shores = epi_12_shores,
  epi_13_cCRE = epi_13_cCRE
)

# Save as RDS for easy loading
saveRDS(all_categories, "all_epivariant_categories.rds")

cat("\n✓ Saved all categories to: all_epivariant_categories.rds\n")
cat("✓ Load with: all_cats <- readRDS('all_epivariant_categories.rds')\n")
```