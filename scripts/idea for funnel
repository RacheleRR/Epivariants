# IMPLEMENTATION: Your 13-Category Structure with Proper Hotspot Parameters
#! THIS MODIFIED CAN BE USEFUL FOR FUNNEL FUNCTION 


## Setup: Helper Functions

```r
# ============================================================
# HELPER FUNCTIONS
# ============================================================

# Auto-calculate min_count based on dataset size
calc_hotspot_threshold <- function(n_epivariants, 
                                   window_mb = 1,
                                   fold_enrichment = 2.5) {
  chr1_length_mb <- 248
  expected_per_chr <- n_epivariants / 22
  n_windows <- chr1_length_mb / window_mb
  expected_per_window <- expected_per_chr / n_windows
  threshold <- ceiling(expected_per_window * fold_enrichment)
  max(threshold, 2)  # minimum of 2
}

# Wrapper for consistent hotspot addition with smart defaults
add_hotspots_smart <- function(epi_df, grset, 
                               window_mb = 1,
                               is_promoter_focused = FALSE) {
  
  n_epi <- nrow(epi_df)
  
  # Adjust parameters based on context
  if (is_promoter_focused) {
    window_mb        <- 0.5
    step_mb          <- 0.25
    min_overlap_frac <- 0.5
  } else {
    step_mb          <- window_mb / 2
    min_overlap_frac <- 0.0
  }
  
  threshold <- calc_hotspot_threshold(n_epi, window_mb)
  
  cat("\nAdding hotspots:\n")
  cat("  Dataset size:     ", n_epi, "epivariants\n")
  cat("  Window size:      ", window_mb, "Mb\n")
  cat("  Step size:        ", step_mb, "Mb\n")
  cat("  Min overlap:      ", min_overlap_frac, "\n")
  cat("  Threshold:        ", threshold, "epivariants per window\n")
  
  result <- get_hotspot_annotation(
    epi_df           = epi_df,
    grset            = grset,
    window_mb        = window_mb,
    step_mb          = step_mb,
    min_overlap_frac = min_overlap_frac,
    min_count        = threshold
  )
  
  cat("  Result: ", sum(result$epi_df_annotated$in_hotspot),
      " / ", nrow(result$epi_df_annotated),
      " (", round(sum(result$epi_df_annotated$in_hotspot) / nrow(result$epi_df_annotated) * 100, 1),
      "%) in hotspots\n")
  
  cat("  Unique hotspots:  ", 
      n_distinct(na.omit(result$epi_df_annotated$hotspot_id)), "\n")
  
  return(result$epi_df_annotated)
}
```

---

## Implementation: All 13 Categories

```r
# ============================================================
# CATEGORY 1: CLEAN (baseline with hotspot info)
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 1: epi_1_clean\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_1_clean <- get_epivariants() %>%
  add_hotspots_smart(grset, is_promoter_focused = FALSE)

write_tsv(epi_1_clean, "epi_1_clean.tsv")


# ============================================================
# CATEGORY 2: CLEAN STRICT (4-5 methods only)
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 2: epi_2_clean_strict\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_2_clean_strict <- get_epivariants() %>%
  filter(tier %in% c("TIER 1: All 5 Methods", "TIER 2: 4 Methods")) %>%
  add_hotspots_smart(grset, is_promoter_focused = FALSE)

write_tsv(epi_2_clean_strict, "epi_2_clean_strict.tsv")


# ============================================================
# CATEGORY 3: FILTERED TO HOTSPOTS ONLY
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 3: epi_3_filt_hs\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_3_filt_hs <- epi_1_clean %>%
  filter(in_hotspot == TRUE)

cat("Filtered to hotspots: ", nrow(epi_3_filt_hs), "regions\n")
write_tsv(epi_3_filt_hs, "epi_3_filt_hs.tsv")


# ============================================================
# CATEGORY 4: ANNOTATION FILTER (promoter/UTR)
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 4: epi_4_filt_annot\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_4_filt_annot <- get_epivariants(
  annotation_filter = list(features = c("Promoter", "5'UTR", "3'UTR"))
) %>%
  add_hotspots_smart(grset, is_promoter_focused = TRUE)  # ← TRUE for promoters

write_tsv(epi_4_filt_annot, "epi_4_filt_annot.tsv")


# ============================================================
# CATEGORY 5: ANNOTATION FILTER → TO HOTSPOTS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 5: epi_5_filt_annot_hs\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_5_filt_annot_hs <- epi_4_filt_annot %>%
  filter(in_hotspot == TRUE)

cat("Filtered to hotspots: ", nrow(epi_5_filt_annot_hs), "regions\n")
write_tsv(epi_5_filt_annot_hs, "epi_5_filt_annot_hs.tsv")


# ============================================================
# CATEGORY 6: BETA FILTER ONLY
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 6: epi_6_filt_beta\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_6_filt_beta <- get_epivariants(
  beta_filter = list(min_abs_delta = 0.2, min_pct_cpgs = 50)
) %>%
  add_hotspots_smart(grset, is_promoter_focused = FALSE)

write_tsv(epi_6_filt_beta, "epi_6_filt_beta.tsv")


# ============================================================
# CATEGORY 7: ANNOTATION + BETA FILTERS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 7: epi_7_filt_annot_beta\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_7_filt_annot_beta <- get_epivariants(
  annotation_filter = list(features = c("Promoter", "5'UTR", "3'UTR")),
  beta_filter = list(min_abs_delta = 0.2, min_pct_cpgs = 50)
) %>%
  add_hotspots_smart(grset, is_promoter_focused = TRUE)

write_tsv(epi_7_filt_annot_beta, "epi_7_filt_annot_beta.tsv")


# ============================================================
# CATEGORY 8: BETA FILTER → TO HOTSPOTS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 8: epi_8_filt_beta_hs\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_8_filt_beta_hs <- epi_6_filt_beta %>%
  filter(in_hotspot == TRUE)

cat("Filtered to hotspots: ", nrow(epi_8_filt_beta_hs), "regions\n")
write_tsv(epi_8_filt_beta_hs, "epi_8_filt_beta_hs.tsv")


# ============================================================
# CATEGORY 9: ANNOTATION + BETA → TO HOTSPOTS (GOLD)
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 9: epi_9_filt_annot_beta_hs (GOLD STANDARD)\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_9_filt_annot_beta_hs <- epi_7_filt_annot_beta %>%
  filter(in_hotspot == TRUE)

cat("Filtered to hotspots: ", nrow(epi_9_filt_annot_beta_hs), "regions\n")
write_tsv(epi_9_filt_annot_beta_hs, "epi_9_filt_annot_beta_hs.tsv")


# ============================================================
# CATEGORY 10: R-SPECIFIC HOTSPOTS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 10: epi_10_R_hotspot\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

# Get R-only epivariants
epi_R_only <- epi_1_clean %>%
  filter(epivariant_class == "R_only")

# Re-run hotspot detection on R-only subset
epi_10_R_hotspot <- epi_R_only %>%
  add_hotspots_smart(grset, is_promoter_focused = FALSE) %>%
  filter(in_hotspot == TRUE)

cat("R-specific hotspots: ", nrow(epi_10_R_hotspot), "regions\n")
write_tsv(epi_10_R_hotspot, "epi_10_R_hotspot.tsv")


# ============================================================
# CATEGORY 11: MR-SPECIFIC HOTSPOTS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 11: epi_11_MR_hotspot\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

# Get MR-only epivariants
epi_MR_only <- epi_1_clean %>%
  filter(epivariant_class == "MR_only")

# Re-run hotspot detection on MR-only subset
epi_11_MR_hotspot <- epi_MR_only %>%
  add_hotspots_smart(grset, is_promoter_focused = FALSE) %>%
  filter(in_hotspot == TRUE)

cat("MR-specific hotspots: ", nrow(epi_11_MR_hotspot), "regions\n")
write_tsv(epi_11_MR_hotspot, "epi_11_MR_hotspot.tsv")


# ============================================================
# CATEGORY 12: CpG SHORES/SHELVES/ISLANDS
# ============================================================

cat("\n", paste(rep("=", 70), collapse = ""), "\n")
cat("CATEGORY 12: epi_12_shores\n")
cat(paste(rep("=", 70), collapse = ""), "\n")

epi_12_shores <- get_epivariants(
  annotation_filter = list(cpgi_context = c("shores", "shelves", "island"))
