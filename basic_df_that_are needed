# Function to save objects appropriately based on their class
save_epi_object <- function(obj, name, folder) {
  file_path <- file.path(folder, name)
  
  # Check if it's a list containing data frames (like bl_base)
  if (is.list(obj) && !is.data.frame(obj) && !is(obj, "tbl_df")) {
    # For bl_base which is a list with multiple components
    if (length(obj) > 1 && all(sapply(obj, function(x) is.data.frame(x) || is(x, "tbl_df")))) {
      # Save each component separately
      for (comp_name in names(obj)) {
        comp_file <- file.path(folder, paste0(name, "_", comp_name, ".rds"))
        saveRDS(obj[[comp_name]], comp_file)
        cat("Saved:", comp_file, "\n")
      }
      # Also save the whole list as RDS
      saveRDS(obj, paste0(file_path, "_list.rds"))
      cat("Saved:", paste0(file_path, "_list.rds"), "\n")
    } else {
      # Save as RDS
      saveRDS(obj, paste0(file_path, ".rds"))
      cat("Saved:", paste0(file_path, ".rds"), "\n")
    }
  } 
  # For data frames and tibbles
  else if (is.data.frame(obj) || is(obj, "tbl_df")) {
    # For very large data frames, use RDS (compressed)
    if (nrow(obj) > 1000000) {
      saveRDS(obj, paste0(file_path, ".rds"))
      cat("Saved (RDS):", paste0(file_path, ".rds"), "\n")
    } else {
      # For smaller data frames, also save as CSV for easy viewing
      write.csv(obj, paste0(file_path, ".csv"), row.names = FALSE)
      saveRDS(obj, paste0(file_path, ".rds"))
      cat("Saved (CSV + RDS):", file_path, "\n")
    }
  }
  # For other objects (like GRanges)
  else {
    saveRDS(obj, paste0(file_path, ".rds"))
    cat("Saved (RDS):", paste0(file_path, ".rds"), "\n")
  }
}

